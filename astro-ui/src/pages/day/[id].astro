---
export const prerender = false;

import MainLayout from '../../layouts/MainLayout.astro';
import fs from 'node:fs';
import path from 'node:path';
import { getNextDay, getPreviousDay, TOTAL_DAYS } from '../../lib/course';

const { id } = Astro.params;
const dayNum = Number.parseInt(id ?? '', 10);

if (!Number.isInteger(dayNum) || dayNum < 1 || dayNum > TOTAL_DAYS) {
	return Astro.redirect('/curriculum');
}

const previousDay = getPreviousDay(dayNum);
const nextDay = getNextDay(dayNum);
const dayDescription = `Day ${dayNum} Linux mission with command drills, guided study sessions, and progress tracking.`;

const mealMeta = [
	{ id: 'breakfast', label: 'Breakfast', icon: '🍳', accent: '#f4c768' },
	{ id: 'lunch', label: 'Lunch', icon: '🥪', accent: '#49d7a8' },
	{ id: 'dinner', label: 'Dinner', icon: '🍽️', accent: '#ff8b7a' },
];

const commandHeads = new Set([
	'adduser', 'alias', 'apt', 'apt-get', 'awk', 'basename', 'bash', 'bzip2', 'cat', 'cd', 'chmod', 'chown',
	'cp', 'crontab', 'curl', 'cut', 'date', 'df', 'diff', 'dig', 'dnf', 'du', 'echo', 'env', 'export', 'find',
	'free', 'fsck', 'getent', 'grep', 'groupadd', 'groupdel', 'groupmod', 'groups', 'gunzip', 'gzip', 'head',
	'hostnamectl', 'htop', 'id', 'ifconfig', 'iostat', 'iptables', 'journalctl', 'kill', 'killall', 'less', 'ln',
	'ls', 'lsof', 'mkdir', 'mount', 'mv', 'nano', 'nc', 'netstat', 'nice', 'nohup', 'nslookup', 'passwd', 'ping',
	'pkill', 'ps', 'pwd', 'renice', 'rm', 'rmdir', 'sar', 'scp', 'sed', 'sha256sum', 'shutdown', 'snort', 'sort',
	'ssh', 'ss', 'stat', 'sudo', 'su', 'swapon', 'systemctl', 'tail', 'tar', 'tee', 'top', 'touch', 'tr', 'tree',
	'umount', 'uname', 'uniq', 'unzip', 'useradd', 'userdel', 'usermod', 'vmstat', 'watch', 'wc', 'wget',
	'whereis', 'which', 'who', 'whoami', 'wireshark', 'xargs', 'xz', 'zip',
]);

const mealFallbackPools = {
	breakfast: [
		'pwd', 'ls -la', 'cd /var/log', 'mkdir -p ~/linux-lab/day-${day}', 'touch notes.txt',
		'cp notes.txt notes.bak', 'mv notes.bak archive-notes.txt', 'cat /etc/os-release',
		'grep -R "error" /var/log', 'find . -type f -name "*.log"', 'chmod 640 notes.txt',
		'chown "$USER":"$USER" notes.txt', 'head -n 20 /var/log/syslog', 'tail -n 50 /var/log/syslog',
		'wc -l /etc/passwd', 'cut -d: -f1 /etc/passwd', 'sort /etc/passwd | uniq', 'echo "study mode on" > status.txt',
	],
	lunch: [
		'ps aux', 'top', 'htop', 'kill -9 PID', 'pkill -f process_name', 'df -h', 'du -sh *',
		'free -h', 'vmstat 1 5', 'iostat -x', 'sar -u 1 3', 'tar -czvf backup.tar.gz ~/linux-lab',
		'tar -xzvf backup.tar.gz', 'gzip logfile.log', 'gunzip logfile.log.gz', 'zip -r project.zip project',
		'unzip project.zip', 'scp file.txt user@host:/tmp',
	],
	dinner: [
		'sudo useradd -m secure_user', 'sudo passwd secure_user', 'sudo usermod -aG sudo secure_user',
		'sudo groupadd ops_team', 'sudo chown -R secure_user:ops_team /srv/app', 'sudo chmod -R 750 /srv/app',
		'sudo systemctl status ssh', 'sudo systemctl restart ssh', 'sudo journalctl -u ssh --since today',
		'sudo iptables -F', 'sudo iptables -P INPUT DROP', 'sudo iptables -A INPUT -p tcp --dport 22 -j ACCEPT',
		'sudo ss -tulpen', 'sudo netstat -plant', 'sudo sha256sum -c checksums.txt', 'sudo tar -xzvf /backups/home_backup.tar.gz -C /',
		'sudo crontab -e', 'sudo hostnamectl set-hostname linux-lab-node',
	],
};

function simpleMarkdown(text) {
	if (!text) return '';

	return text
		.replace(/`\$([\s\S]*?)`/g, '<pre><code>$1</code></pre>')
		.replace(/```([\s\S]*?)```/g, '<pre><code>$1</code></pre>')
		.replace(/^### (.*$)/gm, '<h3>$1</h3>')
		.replace(/^## (.*$)/gm, '<h3>$1</h3>')
		.replace(/^# (.*$)/gm, '<h3>$1</h3>')
		.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
		.replace(/\*(.*?)\*/g, '<em>$1</em>')
		.replace(/^- (.*$)/gm, '<li>$1</li>')
		.replace(/\n/g, '<br>');
}

function normalizeCandidate(line) {
	let command = line.trim();
	if (!command) return '';

	command = command
		.replace(/^[-*+>]\s*/, '')
		.replace(/^Commands?:\s*/i, '')
		.replace(/^Simulated Commands?:\s*/i, '')
		.replace(/^Answer:\s*/i, '')
		.replace(/^Correct Answer:\s*[A-Z]\.\s*/i, '');
	command = command.replace(/^[$#]\s*/, '');
	command = command.replace(/^\d+\.\s+/, '');
	command = command.replace(/\s+#.*$/, '').trim();
	command = command.replace(/\$\{day\}/g, String(dayNum));

	if (command.length < 2 || command.length > 110) return '';
	if (/^https?:\/\//i.test(command)) return '';
	if (!/[a-z]/i.test(command)) return '';
	if (/^\[.*\]\(.*\)$/.test(command)) return '';
	if (!/[\s/_\-|><=]/.test(command) && command.length < 3) return '';

	const tokens = command.split(/\s+/).filter(Boolean);
	let head = tokens[0] || '';
	if (head === 'sudo' && tokens[1]) head = tokens[1];
	if (head === 'env' && tokens[1]) head = tokens[1];
	if (head.includes('/')) {
		head = head.split('/').filter(Boolean).at(-1) || head;
	}
	head = head.replace(/[;:,]+$/, '');

	if (!commandHeads.has(head)) return '';
	if (/[.!?]$/.test(command) && !/[|><]/.test(command)) return '';

	return command;
}

function extractCommands(markdown) {
	const found = [];
	const seen = new Set();

	const add = (candidate) => {
		const normalized = normalizeCandidate(candidate);
		if (!normalized) return;
		if (seen.has(normalized)) return;
		seen.add(normalized);
		found.push(normalized);
	};

	for (const match of markdown.matchAll(/`([^`\n]+)`/g)) {
		add(match[1]);
	}

	for (const block of markdown.matchAll(/```([\s\S]*?)```/g)) {
		const lines = block[1].split('\n');
		for (const line of lines) {
			add(line);
		}
	}

	for (const line of markdown.split('\n')) {
		add(line);
	}

	return found.slice(0, 18);
}

function getFallbackCommands(mealId) {
	const pool = mealFallbackPools[mealId] ?? [];
	if (pool.length === 0) return [];

	const start = (dayNum * 3) % pool.length;
	const picks = [];
	const seen = new Set();

	for (let offset = 0; offset < pool.length && picks.length < 12; offset += 1) {
		const candidate = pool[(start + offset) % pool.length].replace(/\$\{day\}/g, String(dayNum));
		const normalized = normalizeCandidate(candidate);
		if (!normalized || seen.has(normalized)) continue;
		seen.add(normalized);
		picks.push(normalized);
	}

	return picks;
}

function extractResources(markdown) {
	const resources = [];
	const seen = new Set();
	for (const match of markdown.matchAll(/\[([^\]]+)\]\((https?:\/\/[^\s)]+)\)/g)) {
		const label = match[1].trim();
		const url = match[2].trim();
		if (!label || !url || seen.has(url)) continue;
		seen.add(url);
		resources.push({ label, url });
		if (resources.length >= 8) break;
	}
	return resources;
}

function extractTopics(markdown) {
	const topics = [];
	for (const match of markdown.matchAll(/^#{2,3}\s+(.+)$/gm)) {
		const topic = match[1].trim();
		if (!topic) continue;
		topics.push(topic);
		if (topics.length >= 8) break;
	}
	return topics;
}

function getGuideContent(meal) {
	try {
		const lessonsDir = path.join(process.cwd(), 'src/content/lessons');
		if (!fs.existsSync(lessonsDir)) {
			return {
				html: '<p>Content directory not found.</p>',
				raw: '',
				commands: [],
				file: null,
			};
		}

		const files = fs.readdirSync(lessonsDir);
		const dayPattern = new RegExp(`day-0*${dayNum}-`);
		const mealPattern = new RegExp(`${meal}`);

		const targetFile = files.find((f) => dayPattern.test(f) && mealPattern.test(f) && f.endsWith('.md'));

		if (targetFile) {
			const raw = fs.readFileSync(path.join(lessonsDir, targetFile), 'utf-8');
			const extracted = extractCommands(raw);
			const fallback = getFallbackCommands(meal);
			const mergedCommands = [...extracted];
			for (const command of fallback) {
				if (mergedCommands.includes(command)) continue;
				mergedCommands.push(command);
				if (mergedCommands.length >= 12) break;
			}
			return {
				html: simpleMarkdown(raw),
				raw,
				commands: mergedCommands.slice(0, 12),
				resources: extractResources(raw),
				topics: extractTopics(raw),
				file: targetFile,
			};
		}
	} catch (error) {
		console.error(`Error loading ${meal} for day ${dayNum}:`, error);
	}

	return {
		html: `<p>No guide found for ${meal} on Day ${dayNum}.</p>`,
		raw: '',
		commands: getFallbackCommands(meal),
		resources: [],
		topics: [],
		file: null,
	};
}

const mealData = mealMeta.map((meal) => ({
	...meal,
	...getGuideContent(meal.id),
}));

const dayPayload = {
	dayNum,
	meals: mealData.map((meal) => ({
		id: meal.id,
		label: meal.label,
		icon: meal.icon,
		commands: meal.commands,
	})),
};
---

<MainLayout
	title={`Day ${dayNum} Mission Terminal - 30 Days of Linux`}
	description={dayDescription}
	activeNav="curriculum"
>
	<div class="day-shell" data-day-terminal data-day={dayNum}>
		<header class="surface hero-panel">
			<div>
				<a href="/curriculum" class="back-link">← Back to Curriculum</a>
				<h1>Day {dayNum} Mission Terminal</h1>
				<p>Train commands in a live simulation, track XP, and unlock each guide when you're ready.</p>
			</div>
			<div class="mission-stats" aria-label="Mission stats">
				<div class="stat-card">
					<span class="stat-label">XP</span>
					<strong id="xp-value">0</strong>
				</div>
				<div class="stat-card">
					<span class="stat-label">Streak</span>
					<strong id="streak-value">0</strong>
				</div>
				<div class="stat-card">
					<span class="stat-label">Command Mastery</span>
					<strong id="mastery-value">0%</strong>
				</div>
			</div>
		</header>

		<nav class="surface day-nav" aria-label="Day navigation">
			{previousDay ? <a class="day-nav-link" href={`/day/${previousDay}`}>Previous Day ({previousDay})</a> : <span class="day-nav-link disabled">Beginning of Course</span>}
			<a class="day-nav-link" href="/curriculum">Curriculum</a>
			{nextDay ? <a class="day-nav-link" href={`/day/${nextDay}`}>Next Day ({nextDay})</a> : <span class="day-nav-link disabled">Final Day Reached</span>}
		</nav>

		<section class="surface control-rack" aria-label="Mission controls">
			<div class="meal-tabs" role="tablist" aria-label="Meal sessions">
				{mealData.map((meal, index) => (
					<button
						class={`meal-tab ${index === 0 ? 'active' : ''}`}
						type="button"
						data-tab={meal.id}
						role="tab"
						aria-selected={index === 0 ? 'true' : 'false'}
					>
						<span aria-hidden="true">{meal.icon}</span>
						<span>{meal.label}</span>
					</button>
				))}
			</div>
			<div class="music-controls" role="group" aria-label="Music controls">
				<span class="music-label">Study Music</span>
				<button type="button" class="music-btn active" data-music-mode="off">Off</button>
				<button type="button" class="music-btn" data-music-id="jfKfPfyJRdk">Lofi Girl</button>
				<button type="button" class="music-btn" data-music-id="DWcJFNfaw9c">Synthwave</button>
				<button type="button" class="music-btn" data-music-id="4xDzrJKXOOY">Coding Mix</button>
			</div>
		</section>

		<section class="surface music-dock mobile-drawer-panel" data-drawer-panel="global:music" aria-label="YouTube player">
			<div class="music-dock-head drawer-head">
				<h2>YouTube Study Radio</h2>
				<button type="button" class="drawer-close-btn" data-close-drawer aria-label="Close panel">✕</button>
			</div>
			<div class="music-dock-head">
				<p>Pick a track or paste any YouTube URL.</p>
			</div>
			<div class="music-dock-controls">
				<input type="url" data-custom-youtube placeholder="Paste YouTube link (video or playlist)" />
				<button type="button" data-custom-youtube-load>Load Video</button>
			</div>
			<div class="youtube-wrap" data-youtube-wrap hidden>
				<iframe
					data-youtube-frame
					title="Study music player"
					src=""
					allow="autoplay; encrypted-media; picture-in-picture"
					referrerpolicy="strict-origin-when-cross-origin"
					allowfullscreen
				></iframe>
			</div>
		</section>

		<div class="meal-panels">
			{mealData.map((meal, index) => (
				<section
					class={`surface meal-panel ${index === 0 ? 'active' : ''}`}
					data-meal-panel={meal.id}
					style={`--meal-accent:${meal.accent}`}
					hidden={index !== 0}
				>
					<div class="panel-head">
						<h2>{meal.icon} {meal.label} Session</h2>
						<p>Type commands, build streaks, and then review the source guide.</p>
					</div>
					<div class="mission-action-dock">
						<button type="button" class="action-pill" data-open-drawer={`${meal.id}:board`}>Board</button>
						<button type="button" class="action-pill" data-open-drawer={`${meal.id}:intel`}>Intel</button>
						<button type="button" class="action-pill" data-open-drawer={`${meal.id}:boost`}>Boost</button>
						<button type="button" class="action-pill" data-open-drawer={`${meal.id}:guide`}>Guide</button>
						<button type="button" class="action-pill" data-open-drawer="global:music">Music</button>
					</div>

					<div class="mission-grid">
						<article class="terminal-card" aria-live="polite">
							<h3>Live Terminal Drill</h3>
							<p class="muted">Re-type the command exactly to clear each challenge.</p>
							<div class="prompt-line">
								<span class="prompt-prefix">target$</span>
								<code data-target-command={meal.id}>loading...</code>
							</div>
							<div class="input-row">
								<label class="sr-only" for={`cmd-input-${meal.id}`}>Command input</label>
								<input id={`cmd-input-${meal.id}`} data-command-input={meal.id} type="text" placeholder="Type command here" autocomplete="off" />
								<button type="button" data-action="check" data-meal={meal.id}>Run</button>
								<button type="button" data-action="hint" data-meal={meal.id}>Hint</button>
								<button type="button" data-action="skip" data-meal={meal.id}>Skip</button>
							</div>
							<div class="progress-wrap" role="progressbar" aria-label={`${meal.label} mastery`}>
								<div class="progress-bar" data-progress-bar={meal.id}></div>
							</div>
							<p class="progress-text" data-progress-text={meal.id}>0 / {meal.commands.length} mastered</p>
							<ul class="terminal-log" data-log={meal.id}></ul>
						</article>

						<article class="commands-card mobile-drawer-panel" data-drawer-panel={`${meal.id}:board`}>
							<div class="drawer-head">
								<h3>Command Board</h3>
								<button type="button" class="drawer-close-btn" data-close-drawer aria-label="Close panel">✕</button>
							</div>
							<p class="muted">Tap a command when you practiced it in your own terminal.</p>
							<div class="command-chip-grid" data-command-grid={meal.id}>
								{meal.commands.length > 0 ? (
									meal.commands.map((command) => (
										<button type="button" class="command-chip" data-command={command} data-meal={meal.id} title={command}>
											{command}
										</button>
									))
								) : (
									<p class="muted">No commands parsed for this session yet.</p>
								)}
							</div>
						</article>
					</div>

					<article class="command-intel-card mobile-drawer-panel" data-drawer-panel={`${meal.id}:intel`}>
						<div class="drawer-head">
							<h3>Command Intel</h3>
							<button type="button" class="drawer-close-btn" data-close-drawer aria-label="Close panel">✕</button>
						</div>
						<div class="intel-grid">
							<div class="intel-box">
								<h4>Meaning</h4>
								<p data-intel-meaning={meal.id}>Command explanation will appear here.</p>
							</div>
							<div class="intel-box">
								<h4>Sample Output</h4>
								<pre data-intel-output={meal.id}>Output preview will appear here.</pre>
							</div>
							<div class="intel-box">
								<h4>Useful Fun Fact</h4>
								<p data-intel-fact={meal.id}>Fun facts about the active command will appear here.</p>
							</div>
							<div class="intel-box">
								<h4>Last Run Output</h4>
								<pre data-intel-last-run={meal.id}>Run a command to see result feedback.</pre>
							</div>
						</div>
					</article>

					<article class="study-upgrade-card mobile-drawer-panel" data-drawer-panel={`${meal.id}:boost`}>
						<div class="study-upgrade-head">
							<div class="drawer-head">
								<h3>Knowledge Boost</h3>
								<button type="button" class="drawer-close-btn" data-close-drawer aria-label="Close panel">✕</button>
							</div>
							<p>Faster learning with topic cues, mini-missions, and external docs.</p>
						</div>
						<div class="study-upgrade-grid">
							<div class="study-box">
								<h4>Key Topics</h4>
								<div class="topic-chip-grid">
									{meal.topics.length > 0 ? meal.topics.slice(0, 6).map((topic) => <span class="topic-chip">{topic}</span>) : (
										<span class="topic-chip">Linux fundamentals</span>
									)}
								</div>
							</div>
							<div class="study-box">
								<h4>Mini Missions</h4>
								<ul>
									{meal.commands.slice(0, 4).map((command, idx) => (
										<li>Mission {idx + 1}: Run <code>{command}</code> and explain the output in one sentence.</li>
									))}
									{meal.commands.length === 0 && <li>Read the guide once, then summarize three commands you can apply today.</li>}
								</ul>
							</div>
							<div class="study-box">
								<h4>Useful Resources</h4>
								<ul class="resource-list">
									{meal.resources.length > 0 ? meal.resources.slice(0, 6).map((resource) => (
										<li>
											<a href={resource.url} target="_blank" rel="noopener noreferrer">{resource.label}</a>
										</li>
									)) : (
										<>
											<li><a href="https://man7.org/linux/man-pages/" target="_blank" rel="noopener noreferrer">Linux man-pages project</a></li>
											<li><a href="https://www.gnu.org/software/coreutils/manual/coreutils.html" target="_blank" rel="noopener noreferrer">GNU Coreutils manual</a></li>
											<li><a href="https://explainshell.com/" target="_blank" rel="noopener noreferrer">ExplainShell command breakdowns</a></li>
										</>
									)}
								</ul>
							</div>
						</div>
					</article>

					<article class="guide-card mobile-drawer-panel" data-drawer-panel={`${meal.id}:guide`}>
						<div class="guide-head">
							<div class="drawer-head">
								<h3>Study Guide Source</h3>
								<button type="button" class="drawer-close-btn" data-close-drawer aria-label="Close panel">✕</button>
							</div>
							<button type="button" class="guide-toggle" data-toggle-guide={meal.id}>Show Guide</button>
						</div>
						<div class="guide-body" data-guide-body={meal.id} hidden>
							<div class="guide-meta">Source: {meal.file ?? 'No file found'}</div>
							<div class="markdown-content" set:html={meal.html} />
						</div>
					</article>
				</section>
			))}
		</div>
		<button class="drawer-backdrop" type="button" data-drawer-backdrop hidden aria-label="Close panel"></button>

		<script type="application/json" id="day-terminal-data" set:html={JSON.stringify(dayPayload)} />
	</div>
</MainLayout>

<script>
	const statusLines = {
		success: [
			'Command accepted. Nice execution.',
			'Clean run. System confidence increased.',
			'Mission step complete. Keep pushing.',
		],
		failure: [
			'Not quite. Re-check the flags and spacing.',
			'Command mismatch. Try again carefully.',
			'Close, but syntax is off. Use a hint if needed.',
		],
	};

	const normalize = (value) => value.trim().replace(/^[$#]\s*/, '').replace(/\s+/g, ' ');
	const pick = (items) => items[Math.floor(Math.random() * items.length)];
	const getBaseCommand = (command) => normalize(command).split(' ')[0] || '';
	const cleanArg = (command, index = 1) => {
		const parts = normalize(command).split(' ');
		return parts[index] || '';
	};

	const commandIntelMap = {
		ls: {
			meaning: 'Lists files and directories so you can inspect what is in the current location.',
			output: 'Documents\nscripts\nnotes.txt\n',
			fact: 'Combine `ls -lah` to reveal hidden files and human-readable file sizes in one pass.',
		},
		cd: {
			meaning: 'Changes your working directory so later commands run in a different location.',
			output: '(directory changed)\n',
			fact: 'Use `cd -` to jump back to your previous directory instantly.',
		},
		pwd: {
			meaning: 'Prints the absolute path of your current directory.',
			output: '/home/neo/30days/30-days-of-Linux-Fundamentals\n',
			fact: 'When a script behaves unexpectedly, `pwd` is the fastest sanity check.',
		},
		cat: {
			meaning: 'Reads and prints file contents directly to the terminal.',
			output: 'server_mode=true\nlog_level=info\n',
			fact: '`cat` is great for quick reads; use `less` for large files you need to scroll.',
		},
		grep: {
			meaning: 'Searches text for lines matching a pattern.',
			output: '42:ERROR failed to bind socket\n',
			fact: '`grep -RIn` is a powerful codebase search combo for recursive, line-numbered matches.',
		},
		find: {
			meaning: 'Recursively locates files/directories by name, type, time, size, and more.',
			output: './logs/app.log\n./logs/archive/app-2026-04.log\n',
			fact: 'Pair `find` with `-exec` for one-command bulk operations.',
		},
		mkdir: {
			meaning: 'Creates new directories.',
			output: '(directory created)\n',
			fact: '`mkdir -p a/b/c` creates nested paths without errors for existing parents.',
		},
