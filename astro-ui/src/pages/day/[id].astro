	function buildCommandIntel(command) {
		const normalized = normalize(command);
		if (!normalized) {
			return {
				meaning: 'No command selected yet.',
				output: 'Output preview unavailable.',
				fact: 'Pick a command challenge to begin.',
			};
		}

		const base = getBaseCommand(normalized);
		const template = commandIntelMap[base];
		if (template) return template;

		const arg = cleanArg(normalized) || '<target>';
		return {
			meaning: `Runs \`${base}\` on ${arg} to perform a Linux task in this training mission.`,
			output: `$ ${normalized}\n(command executed in training simulation)\n`,
			fact: `Check \`man ${base}\` for complete flags and real-world usage patterns.`,
		};
	}

	function parseYouTubeInput(input) {
		const raw = String(input || '').trim();
		if (!raw) return null;
		if (/^[a-zA-Z0-9_-]{11}$/.test(raw)) {
			return `https://www.youtube.com/embed/${raw}?autoplay=1&rel=0&modestbranding=1`;
		}

		try {
			const url = new URL(raw);
			if (url.hostname.includes('youtu.be')) {
				const id = url.pathname.replace('/', '').trim();
				if (id) {
					return `https://www.youtube.com/embed/${id}?autoplay=1&rel=0&modestbranding=1`;
				}
			}

			const videoId = url.searchParams.get('v');
			const listId = url.searchParams.get('list');
			if (videoId) {
				return `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&modestbranding=1`;
			}
			if (listId) {
				return `https://www.youtube.com/embed/videoseries?autoplay=1&list=${encodeURIComponent(listId)}`;
			}
		} catch (_error) {
			return null;
		}

		return null;
	}

	function initDayTerminal() {
		const root = document.querySelector('[data-day-terminal]');
		if (!root || root.dataset.bound === 'true') return;
		root.dataset.bound = 'true';

		const payloadNode = root.querySelector('#day-terminal-data');
		if (!payloadNode) return;
		const payload = JSON.parse(payloadNode.textContent || '{}');
		const meals = payload.meals || [];
		const dayNum = payload.dayNum;

		if (!Array.isArray(meals) || meals.length === 0) return;

		const storageKey = `linux30-day-${dayNum}-terminal-state`;
		const courseProgressKey = 'linux30-course-progress-v1';
		const totalCommands = meals.reduce((count, meal) => count + (meal.commands?.length || 0), 0);
		const commandMap = Object.fromEntries(meals.map((meal) => [meal.id, meal.commands || []]));
		const targets = {};
		const youtubeWrap = root.querySelector('[data-youtube-wrap]');
		const youtubeFrame = root.querySelector('[data-youtube-frame]');
		const customYoutubeInput = root.querySelector('[data-custom-youtube]');
		const customYoutubeLoad = root.querySelector('[data-custom-youtube-load]');
		const drawerBackdrop = root.querySelector('[data-drawer-backdrop]');
		let activeDrawer = '';

		const defaultState = {
			activeMeal: meals[0].id,
			xp: 0,
			streak: 0,
			musicEmbed: '',
			solved: Object.fromEntries(meals.map((meal) => [meal.id, []])),
			guideOpen: Object.fromEntries(meals.map((meal) => [meal.id, false])),
			lastRun: Object.fromEntries(meals.map((meal) => [meal.id, 'Run a command to see result feedback.'])),
		};

		let state = structuredClone(defaultState);
		try {
			const saved = localStorage.getItem(storageKey);
			if (saved) {
				const parsed = JSON.parse(saved);
				state = {
					...state,
					...parsed,
					solved: { ...defaultState.solved, ...(parsed.solved || {}) },
					guideOpen: { ...defaultState.guideOpen, ...(parsed.guideOpen || {}) },
					lastRun: { ...defaultState.lastRun, ...(parsed.lastRun || {}) },
				};
			}
		} catch (_error) {
			state = structuredClone(defaultState);
		}

		if (!commandMap[state.activeMeal]) {
			state.activeMeal = meals[0].id;
		}

		function syncCourseProgress() {
			let existing = { completedDays: [], lastVisitedDay: dayNum };
			try {
				existing = JSON.parse(localStorage.getItem(courseProgressKey) || 'null') || existing;
			} catch (_error) {
				existing = { completedDays: [], lastVisitedDay: dayNum };
			}

			const completedDays = new Set(
				Array.isArray(existing.completedDays)
					? existing.completedDays
						.map((value) => Number(value))
						.filter((value) => Number.isInteger(value) && value >= 1 && value <= 30)
					: [],
			);
			const solvedCount = meals.reduce((count, meal) => count + (state.solved[meal.id]?.length || 0), 0);
			const dayIsComplete = totalCommands > 0 && solvedCount >= totalCommands;

			if (dayIsComplete) {
				completedDays.add(dayNum);
			}

			localStorage.setItem(
				courseProgressKey,
				JSON.stringify({
					completedDays: Array.from(completedDays).sort((a, b) => a - b),
					lastVisitedDay: dayNum,
					updatedAt: new Date().toISOString(),
				}),
			);
		}

		const save = () => {
			localStorage.setItem(storageKey, JSON.stringify(state));
			syncCourseProgress();
		};

		const getSolvedSet = (mealId) => new Set(state.solved[mealId] || []);
		const setSolved = (mealId, valueSet) => {
			state.solved[mealId] = Array.from(valueSet);
		};

		const setTarget = (mealId, preferred) => {
			const commands = commandMap[mealId] || [];
			if (commands.length === 0) {
				targets[mealId] = null;
				return;
			}
			if (preferred) {
				targets[mealId] = preferred;
				return;
			}
			const solved = getSolvedSet(mealId);
			const unresolved = commands.filter((cmd) => !solved.has(cmd));
			const pool = unresolved.length > 0 ? unresolved : commands;
			targets[mealId] = pick(pool);
		};

		const log = (mealId, text, tone = 'neutral') => {
			const list = root.querySelector(`[data-log="${mealId}"]`);
			if (!list) return;
			const item = document.createElement('li');
			item.textContent = text;
			item.className = `log-${tone}`;
			list.prepend(item);
			while (list.children.length > 6) {
				list.removeChild(list.lastElementChild);
			}
		};

		const renderStats = () => {
			const solvedCount = meals.reduce((count, meal) => count + (state.solved[meal.id]?.length || 0), 0);
			const mastery = totalCommands === 0 ? 0 : Math.round((solvedCount / totalCommands) * 100);

			const xpEl = root.querySelector('#xp-value');
			const streakEl = root.querySelector('#streak-value');
			const masteryEl = root.querySelector('#mastery-value');
			if (xpEl) xpEl.textContent = String(state.xp);
			if (streakEl) streakEl.textContent = String(state.streak);
			if (masteryEl) masteryEl.textContent = `${mastery}%`;
			return mastery;
		};

		const renderPerMeal = (mealId) => {
			const commands = commandMap[mealId] || [];
			const solved = getSolvedSet(mealId);
			const target = targets[mealId];
			const targetEl = root.querySelector(`[data-target-command="${mealId}"]`);
			if (targetEl) targetEl.textContent = target || 'No commands available for this meal.';
			const intel = buildCommandIntel(target || '');
			const meaningEl = root.querySelector(`[data-intel-meaning="${mealId}"]`);
			const outputEl = root.querySelector(`[data-intel-output="${mealId}"]`);
			const factEl = root.querySelector(`[data-intel-fact="${mealId}"]`);
			const lastRunEl = root.querySelector(`[data-intel-last-run="${mealId}"]`);
			if (meaningEl) meaningEl.textContent = intel.meaning;
			if (outputEl) outputEl.textContent = intel.output;
			if (factEl) factEl.textContent = intel.fact;
			if (lastRunEl) lastRunEl.textContent = state.lastRun[mealId] || 'Run a command to see result feedback.';

			const progressEl = root.querySelector(`[data-progress-text="${mealId}"]`);
			const progressBar = root.querySelector(`[data-progress-bar="${mealId}"]`);
			if (progressEl) progressEl.textContent = `${solved.size} / ${commands.length} mastered`;
			if (progressBar) {
				const percent = commands.length ? Math.round((solved.size / commands.length) * 100) : 0;
				progressBar.style.width = `${percent}%`;
			}

			root.querySelectorAll(`[data-meal="${mealId}"][data-command]`).forEach((button) => {
				const command = button.dataset.command;
				if (!command) return;
				button.classList.toggle('done', solved.has(command));
			});

			const guideBody = root.querySelector(`[data-guide-body="${mealId}"]`);
			const guideToggle = root.querySelector(`[data-toggle-guide="${mealId}"]`);
			const open = Boolean(state.guideOpen[mealId]);
			if (guideBody) guideBody.hidden = !open;
			if (guideToggle) guideToggle.textContent = open ? 'Hide Guide' : 'Show Guide';
		};

		const renderTabs = () => {
			root.querySelectorAll('[data-tab]').forEach((tab) => {
				const isActive = tab.dataset.tab === state.activeMeal;
				tab.classList.toggle('active', isActive);
				tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
			});

			root.querySelectorAll('[data-meal-panel]').forEach((panel) => {
				const isActive = panel.dataset.mealPanel === state.activeMeal;
				panel.classList.toggle('active', isActive);
				panel.hidden = !isActive;
			});
		};

		const renderDrawers = () => {
			root.querySelectorAll('[data-drawer-panel]').forEach((panel) => {
				const panelId = panel.dataset.drawerPanel;
				panel.classList.toggle('open', panelId === activeDrawer);
			});
			if (drawerBackdrop instanceof HTMLButtonElement) {
				const open = Boolean(activeDrawer);
				drawerBackdrop.hidden = !open;
				drawerBackdrop.classList.toggle('open', open);
			}
		};

		const closeDrawer = () => {
			activeDrawer = '';
			renderDrawers();
		};

		const openDrawer = (panelId) => {
			if (!panelId) return;
			activeDrawer = panelId;
			renderDrawers();
		};

		const setYoutubeEmbed = (embedUrl) => {
			if (!(youtubeWrap instanceof HTMLElement) || !(youtubeFrame instanceof HTMLIFrameElement)) return;
			const normalized = String(embedUrl || '').trim();
			if (!normalized) {
				youtubeWrap.hidden = true;
				youtubeFrame.src = '';
				return;
			}
			youtubeWrap.hidden = false;
			youtubeFrame.src = normalized;
		};

		const setMusic = (embedUrl) => {
			state.musicEmbed = embedUrl || '';
			save();
			setYoutubeEmbed(state.musicEmbed);

			root.querySelectorAll('[data-music-mode], [data-music-id]').forEach((button) => {
				const mode = button.dataset.musicMode;
				const id = button.dataset.musicId;
				const active = (mode === 'off' && !state.musicEmbed) || (id && state.musicEmbed.includes(`/embed/${id}`));
				button.classList.toggle('active', Boolean(active));
			});
		};

		const award = (mealId, amount, message, tone) => {
			state.xp = Math.max(0, state.xp + amount);
			log(mealId, message, tone);
		};

		meals.forEach((meal) => setTarget(meal.id));

		root.querySelectorAll('[data-tab]').forEach((tab) => {
			tab.addEventListener('click', () => {
				const mealId = tab.dataset.tab;
				if (!mealId) return;
				state.activeMeal = mealId;
				renderTabs();
				closeDrawer();
				save();
			});
		});

		root.querySelectorAll('[data-open-drawer]').forEach((button) => {
			button.addEventListener('click', () => openDrawer(button.dataset.openDrawer));
		});

		root.querySelectorAll('[data-close-drawer]').forEach((button) => {
			button.addEventListener('click', closeDrawer);
		});

		if (drawerBackdrop instanceof HTMLButtonElement) {
			drawerBackdrop.addEventListener('click', closeDrawer);
		}

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && activeDrawer) {
				closeDrawer();
			}
		});

		root.querySelectorAll('[data-action]').forEach((button) => {
			button.addEventListener('click', () => {
				const mealId = button.dataset.meal;
				const action = button.dataset.action;
				if (!mealId || !action) return;
				const input = root.querySelector(`[data-command-input="${mealId}"]`);
				const target = targets[mealId];

				if (action === 'skip') {
					state.streak = 0;
					setTarget(mealId);
					renderPerMeal(mealId);
					save();
					award(mealId, -1, 'Skipped challenge. New target loaded.', 'neutral');
					renderStats();
					return;
				}

				if (!target || !(input instanceof HTMLInputElement)) return;

				if (action === 'hint') {
					const firstSegment = target.split(' ')[0];
					award(mealId, 0, `Hint: starts with \"${firstSegment}\".`, 'neutral');
					return;
				}

				if (action === 'check') {
					const entered = normalize(input.value);
					const expected = normalize(target);
					const enteredIntel = buildCommandIntel(entered);
					if (entered === expected) {
						const solved = getSolvedSet(mealId);
						const firstSolve = !solved.has(target);
						solved.add(target);
						setSolved(mealId, solved);
						state.streak += 1;
						state.lastRun[mealId] = `$ ${entered}\n${enteredIntel.output}`;
						award(mealId, firstSolve ? 15 : 4, pick(statusLines.success), 'success');
						setTarget(mealId);
						input.value = '';
						renderPerMeal(mealId);
					} else {
						state.streak = 0;
						state.lastRun[mealId] = `$ ${entered || '(empty command)'}\ncommand not accepted in mission mode\nhint: ${expected}`;
						award(mealId, -2, pick(statusLines.failure), 'failure');
						renderPerMeal(mealId);
					}

					renderStats();
					save();
				}
			});
		});

		root.querySelectorAll('[data-command-input]').forEach((field) => {
			field.addEventListener('keydown', (event) => {
				if (event.key !== 'Enter') return;
				event.preventDefault();
				const mealId = field.dataset.commandInput;
				const runBtn = root.querySelector(`[data-action="check"][data-meal="${mealId}"]`);
				if (runBtn instanceof HTMLButtonElement) {
					runBtn.click();
				}
			});
		});

		root.querySelectorAll('[data-command]').forEach((button) => {
			button.addEventListener('click', () => {
				const command = button.dataset.command;
				const mealId = button.dataset.meal;
				if (!command || !mealId) return;
				const solved = getSolvedSet(mealId);
				if (solved.has(command)) {
					solved.delete(command);
					setSolved(mealId, solved);
					award(mealId, -3, `Practice unchecked: ${command}`, 'neutral');
				} else {
					solved.add(command);
					setSolved(mealId, solved);
					award(mealId, 6, `Practice logged: ${command}`, 'success');
				}

				renderPerMeal(mealId);
				renderStats();
				save();
			});
		});

		root.querySelectorAll('[data-toggle-guide]').forEach((button) => {
			button.addEventListener('click', () => {
				const mealId = button.dataset.toggleGuide;
				if (!mealId) return;
				state.guideOpen[mealId] = !state.guideOpen[mealId];
				renderPerMeal(mealId);
				save();
			});
		});

		root.querySelectorAll('[data-music-mode], [data-music-id]').forEach((button) => {
			button.addEventListener('click', () => {
				const mode = button.dataset.musicMode;
				const videoId = button.dataset.musicId;
				if (mode === 'off') {
					setMusic('');
					return;
				}
				if (videoId) {
					setMusic(parseYouTubeInput(videoId) || '');
				}
			});
		});

		if (customYoutubeLoad instanceof HTMLButtonElement && customYoutubeInput instanceof HTMLInputElement) {
			customYoutubeLoad.addEventListener('click', () => {
				const embed = parseYouTubeInput(customYoutubeInput.value);
				if (!embed) {
					log(state.activeMeal, 'Could not parse that YouTube URL. Try a valid video or playlist link.', 'failure');
					return;
				}
				setMusic(embed);
				log(state.activeMeal, 'YouTube track loaded.', 'success');
				customYoutubeInput.value = '';
			});
		}

		renderTabs();
		meals.forEach((meal) => renderPerMeal(meal.id));
		renderStats();
		renderDrawers();
		setYoutubeEmbed(state.musicEmbed);
		syncCourseProgress();
		root.querySelectorAll('[data-music-mode], [data-music-id]').forEach((button) => {
			const mode = button.dataset.musicMode;
			const id = button.dataset.musicId;
			const active = (mode === 'off' && !state.musicEmbed) || (id && state.musicEmbed.includes(`/embed/${id}`));
			button.classList.toggle('active', Boolean(active));
		});
	}

	document.addEventListener('DOMContentLoaded', initDayTerminal);
	document.addEventListener('astro:page-load', initDayTerminal);
</script>

